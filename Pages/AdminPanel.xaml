<Page x:Class="DemExamen_8.Pages.AdminPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemExamen_8.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
          Title="Панель администратора">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>
    <Grid Background="Gray">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Управление пользователями" 
           FontSize="24" 
           FontWeight="Bold" 
           HorizontalAlignment="Center"
           Margin="0,0,0,20"/>

        <!-- Форма добавления/редактирования -->
        <Border Grid.Row="1" 
        BorderBrush="Gray" 
        BorderThickness="1" 
        CornerRadius="5" 
        Padding="10" 
        Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Добавление / Редактирование пользователя" 
                   FontSize="16" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Логин:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtLogin" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Пароль:" Grid.Row="1" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="TxtPassword" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="Роль:" Grid.Row="2" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbRole" Grid.Row="2" Grid.Column="1" Margin="5">
                        <ComboBoxItem Content="Администратор" Tag="1"/>
                        <ComboBoxItem Content="Пользователь" Tag="2"/>
                    </ComboBox>

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal" 
                        HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="BtnAdd" Content="Добавить" Width="100" 
                        Margin="5" Click="BtnAdd_Click"/>
                        <Button x:Name="BtnUpdate" Content="Обновить" Width="100" 
                        Margin="5" Click="BtnUpdate_Click"/>
                        <Button x:Name="BtnClear" Content="Очистить" Width="100" 
                        Margin="5" Click="BtnClear_Click"/>
                        <Button x:Name="BtnNazad" Content="Назад" Width="100"
                        Margin="5" Click="BtnNazad_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Таблица пользователей -->
        <DataGrid Grid.Row="2" 
          x:Name="DgUsers" 
          AutoGenerateColumns="False" 
          SelectionChanged="DgUsers_SelectionChanged"
          IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id_Polzovateli}" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="150"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Roli.Name_Roli}" Width="120"/>
                <DataGridCheckBoxColumn Header="Заблокирован" Binding="{Binding Blocked}" Width="100"/>
                <DataGridTextColumn Header="Попытки входа" Binding="{Binding Popitki_Vhoda}" Width="100"/>

                <!-- Кнопка разблокировки -->
                <DataGridTemplateColumn Header="Разблокировка" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button x:Name="BtnUnblock" 
                    Content="Разблокировать" 
                    Click="BtnUnblock_Click" 
                    Tag="{Binding Id_Polzovateli}"
                    Background="#FF27AE60" 
                    Foreground="White"
                    BorderThickness="0"
                    Padding="5"
                    Visibility="{Binding Blocked, Converter={StaticResource BoolToVisibility}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
